/dts-v1/;
#include <st/g4/stm32g491Xe.dtsi>
#include <st/g4/stm32g491c(c-e)tx-pinctrl.dtsi>
#include <zephyr/dt-bindings/display/panel.h>
#include <zephyr/dt-bindings/mipi_dbi/mipi_dbi.h>
#include <zephyr/dt-bindings/led/led.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "Hydrogreen Steering wheel board";
	compatible = "hydrogreen,steering-wheel";

	aliases {
		can-rx-led = &can_rx_led;
		can-tx-led = &can_tx_led;
		can = &fdcan2;
		button-emergency = &button_emergency;
		button-start = &button_start;
		button-reset = &button_reset;
		button-lap-time = &button_lap_time;
		button-deadman = &button_deadman;
		button-test = &button_test;
		watchdog0 = &iwdg;
		die-temp0 = &die_temp;
		volt-sensor0 = &vref;
		volt-sensor1 = &vbat;
	};

	chosen {
		zephyr,display = &ili9341;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,canbus = &fdcan2;
		zephyr,code-partition = &slot0_partition;
	};

	mipi_dbi {
		compatible = "zephyr,mipi-dbi-spi";
		spi-dev = <&spi1>;
		dc-gpios = <&gpiob 2 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&gpiob 1 GPIO_ACTIVE_LOW>;
		write-only;
		#address-cells = <1>;
		#size-cells = <0>;
		status = "okay";

		ili9341: ili9341@0 {
			compatible = "ilitek,ili9341";
			mipi-max-frequency = <24000000>;
			reg = <0>;
			pixel-format = <PANEL_PIXEL_FORMAT_RGB_565>;
			//display-inversion;
			rotation = <90>;
			width = <240>;
			height = <320>;

			status = "okay";

		};
	};
};


&gpioa {
	status = "okay";
};

&gpiob {
	status = "okay";
};


&clk_lsi {
	status = "okay";
};

&clk_hsi48 {
	status = "okay";
};

//&clk_hse {
//	clock-frequency = <DT_FREQ_M(24)>;
//	status = "okay";
//};

&clk_hsi {
	//	clock-frequency = <DT_FREQ_M(16)>;
	status = "okay";
};

&pll {
	div-m = <1>;
	mul-n = <10>;
	div-p = <2>;
	div-q = <2>;
	div-r = <2>;
	clocks = <&clk_hsi>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(80)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <1>;
	apb2-prescaler = <1>;
};

