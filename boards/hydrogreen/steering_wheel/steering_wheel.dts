//		   <&dmamux1 1 24 STM32_DMA_PERIPH_RX>;
//	dma-names = "tx", "rx";
//};

&dma1 {
	status = "okay";
};

&dmamux1 {
	status = "okay";
};

&spi1 {
	pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
	pinctrl-names = "default";
	cs-gpios = <&gpiob 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;

	dmas = <&dma1 1 11 (STM32_DMA_PERIPH_TX | STM32_DMA_PRIORITY_HIGH)>,
		   <&dma1 2 10 (STM32_DMA_PERIPH_RX | STM32_DMA_PRIORITY_HIGH)>;
	dma-names = "tx", "rx";

	status = "okay";
